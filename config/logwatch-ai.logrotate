# logrotate configuration for logwatch-ai logs
# Place this file at: /etc/logrotate.d/logwatch-ai

/var/log/logwatch-ai.log
/var/log/logwatch-ai-cron.log
{
    daily
    rotate 7
    compress
    delaycompress
    notifempty
    create 0640 root adm
    sharedscripts
    postrotate
        systemctl reload syslog >/dev/null 2>&1 || true
    endscript
}
