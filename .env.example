# DeepSeek API Configuration
DEEPSEEK_API_KEY=sk-your-api-key-here

# Logwatch Configuration
LOGWATCH_DETAIL=medium
LOGWATCH_SERVICES=messages,apache-access,nginx,sshd,ufw

# Email Configuration (Local postfix)
SMTP_HOST=localhost
SMTP_PORT=25
MAIL_FROM=logwatch-ai@localhost
ADMIN_EMAIL=nishimura@69.nyanta.jp

# Output Directory
ANALYZED_REPORT_OUTPUT=/var/tmp
LOGWATCH_LOG_DIR=/var/log

# Script Logging
LOG_LEVEL=INFO
SCRIPT_LOG_FILE=/var/log/logwatch-ai.log

# API Retry Configuration
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_TIMEOUT=30
DEEPSEEK_RETRY_BACKOFF_FACTOR=2
